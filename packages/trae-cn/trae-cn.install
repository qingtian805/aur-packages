GREEN='\e[1;32m'
BLUE='\e[1;34m'
YELLOW='\e[1;33m'
RESET='\e[0m'

post_install() {
    echo -e "\n${GREEN}  Trae CN has been successfully installed!${RESET}"
    echo -e "  -> ${BLUE}Launch command:${RESET} trae-cn"
    echo -e "  -> ${BLUE}Configuration directory:${RESET} ~/.config/trae-cn"
    echo -e "  -> ${BLUE}User flags configuration file:${RESET} ~/.config/trae-cn-flags.conf\n"
}

post_upgrade() {
    echo -e "\n${GREEN}  Trae CN has been upgraded to version $1!${RESET}\n"
}

post_remove() {
    echo -e "\n${YELLOW}  Trae CN has been successfully removed.${RESET}"
    echo -e "  -> User profile files were kept in: ~/.config/trae-cn/\n"
}
