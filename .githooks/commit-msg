#!/usr/bin/env bash
# Conventional Commits 1.0.0 enforcement
# https://www.conventionalcommits.org/

commit_msg=$(cat "$1")

# Allow empty commits
if [ -z "$commit_msg" ]; then
    exit 0
fi

# Allowed types
types="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# Pattern: type(scope): description  or  type: description
# - type: required, one of the allowed types
# - scope: optional, alphanumeric + hyphen/underscore
# - description: required, non-empty
# - ! after type/scope indicates breaking change
pattern="^(${types})(\([a-zA-Z0-9_-]+\))?!?: .+"

# Check first line only
first_line=$(echo "$commit_msg" | head -n1)

if ! echo "$first_line" | grep -qE "$pattern"; then
    echo "ERROR: Commit message does not follow Conventional Commits format."
    echo ""
    echo "  Format: <type>(<scope>): <description>"
    echo ""
    echo "  Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
    echo "  Scope: optional, e.g. (downloader), (qq), (ci)"
    echo ""
    echo "  Examples:"
    echo "    feat(qq): add loong64 architecture support"
    echo "    fix: handle empty version string"
    echo "    docs: update CLAUDE.md with new conventions"
    echo "    refactor(downloader): simplify retry logic"
    echo "    chore: upgrade dependencies"
    echo ""
    echo "  Got: $first_line"
    exit 1
fi
